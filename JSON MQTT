    {
        "id": "fn_status_energi",
        "type": "function",
        "z": "tab_plts",
        "name": "Status Energi",
        "func": "var d = msg.payload;\nmsg.payload = d.status_energi + ' | PV: ' + parseFloat(d.energi_pv).toFixed(2) + ' Wh | Beban: ' + parseFloat(d.energi_beban).toFixed(2) + ' Wh';\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 300,
        "wires": [
            [
                "text_status_energi"
            ]
        ]
    },
    {
        "id": "fn_status_baterai",
        "type": "function",
        "z": "tab_plts",
        "name": "function 1",
        "func": "var d = msg.payload;\nvar soc = parseFloat(d.soc);\nvar status = d.status_baterai;\nvar icon = soc >= 80 ? '🔋' : soc >= 40 ? '🔋' : soc >= 20 ? '🪫' : '⚠️';\nmsg.payload = icon + ' ' + status + ' (' + soc.toFixed(1) + '%)';\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 340,
        "wires": [
            [
                "text_status_baterai"
            ]
        ]
    },
    {
        "id": "fn_tracker",
        "type": "function",
        "z": "tab_plts",
        "name": "Tracker",
        "func": "var d = msg.payload;\nnode.send([\n  {payload: d.pos_h},\n  {payload: d.pos_v},\n  {payload: d.arah_yaw + ' | ' + d.arah_pitch},\n  {payload: d.mode}\n]);\n",
        "outputs": 4,
        "x": 500,
        "y": 380,
        "wires": [
            [
                "gauge_pos_h"
            ],
            [
                "gauge_pos_v"
            ],
            [
                "text_arah"
            ],
            [
                "text_mode"
            ]
        ]
    },
    {
        "id": "fn_ldr",
        "type": "function",
        "z": "tab_plts",
        "name": "LDR",
        "func": "var d = msg.payload;\nnode.send([\n  {payload: d.ldr_atas},\n  {payload: d.ldr_bawah},\n  {payload: d.ldr_kiri},\n  {payload: d.ldr_kanan}\n]);\n",
        "outputs": 4,
        "x": 500,
        "y": 420,
        "wires": [
