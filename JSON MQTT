            [
                "gauge_ldr_bawah"
            ],
            [
                "gauge_ldr_kiri"
            ],
            [
                "gauge_ldr_kanan"
            ]
        ]
    },
    {
        "id": "fn_chart",
        "type": "function",
        "z": "tab_plts",
        "name": "Chart Split",
        "func": "var d = msg.payload;\nnode.send([\n  {payload: parseFloat(d.tegangan), topic: 'Tegangan (V)'},\n  {payload: parseFloat(d.arus_pv),  topic: 'Arus PV (A)'},\n  {payload: parseFloat(d.daya_pv),  topic: 'Daya PV (W)'}\n]);\n",
