#include <ESP32Servo.h>
#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoJson.h>
#include <Wire.h>              
#include <Adafruit_ADS1X15.h>  

// ===================== WIFI & MQTT =====================
const char* ssid       = "Alifa";
const char* password   = "Alifa123";
const char* mqttServer = "10.20.146.254";
const int   mqttPort   = 1883;
const char* mqttUser   = "";
const char* mqttPass   = "";

// ===================== TOPIC MQTT =====================
#define TOPIC_DATA  "plts/data"
#define TOPIC_CMD   "plts/cmd"

// ===================== PIN =====================
#define LDR_ATAS            34
#define LDR_BAWAH           35
#define LDR_KIRI            32
#define LDR_KANAN           33
#define SENSOR_VOLT_PV      39   
#define SENSOR_ARUS_PV      36   
// ADS1115 Channel:
// A0 = Sensor tegangan beban
// A1 = Sensor TEMT6000 (cahaya)
// A2 =  Sensor arus beban
#define SERVO_HORIZONTAL    26
#define SERVO_VERTICAL      27

// ===================== ADS1115 =====================
Adafruit_ADS1115 ads;
bool adsReady = false;

// ===================== SERVO =====================
Servo servoH;
Servo servoV;

int posisiH = 90;
int posisiV = 90;

// ===================== PARAMETER =====================
int  batasCahaya    = 30;
int  toleransiYaw   = 5;
int  toleransiPitch = 5;
bool modeManual     = false;

// ===================== KALIBRASI VOLT =====================
float faktorKalibrasiVolt      = 1.0388;  
float faktorKalibrasiVoltBeban = 1.1615;  

// ===================== ACS712 PV =====================
float offsetACS_PV       = 2.50;
float sensitivitasACS_PV = 0.100;
float arusFilter_PV      = 0;

// ===================== ACS712 BEBAN =====================
float offsetACS_Beban       = 2.50;
float sensitivitasACS_Beban = 0.100;
float arusFilter_Beban      = 0;

// ===================== ENERGI =====================
float         energiWhPV     = 0;
float         energiWhBeban  = 0;
unsigned long lastEnergiTime = 0;

// ===================== MQTT CLIENT =====================
WiFiClient   espClient;
PubSubClient mqttClient(espClient);

unsigned long lastPublish     = 0;
const long    publishInterval = 1000;

// ===================================================
// ADC AVERAGING (ADC internal ESP32)
// ===================================================
int bacaADC(int pin) {
  long total = 0;
  for (int i = 0; i < 20; i++) {
    total += analogRead(pin);
    delayMicroseconds(100);
  }
  return total / 20;
}

// ===================================================
// TEGANGAN PV (ADC internal ESP32)
// ===================================================
float bacaVoltagePV() {
  int   adc = bacaADC(SENSOR_VOLT_PV);
  float v   = (adc * 3.3f) / 4095.0f;
  return v * 5.0f * faktorKalibrasiVolt;
}

// ===================================================
// TEGANGAN BEBAN (via ADS1115 channel A0)
// ===================================================
float bacaVoltageBeban() {
  if (!adsReady) return 0.0f;
  int16_t raw = ads.readADC_SingleEnded(0); // A0
  float   v   = ads.computeVolts(raw);
  return v * 5.0f * faktorKalibrasiVoltBeban;
}

// ===================================================
// ARUS PV (ADC internal ESP32)
// ===================================================
float bacaArusPV() {
  int   adc  = bacaADC(SENSOR_ARUS_PV);
  float v    = (adc * 5.0f) / 4095.0f;
  float arus = ((v - offsetACS_PV) / sensitivitasACS_PV) * 0.0750f;
  if (abs(arus) < 0.10f) arus = 0;
  arusFilter_PV = (0.85f * arusFilter_PV) + (0.15f * arus);
  arusFilter_PV = constrain(arusFilter_PV, -50.0f, 50.0f);
  return arusFilter_PV;
}

// ===================================================
// ARUS BEBAN (ADC internal ESP32)
// ===================================================
float bacaArusBeban() {
  if (!adsReady) return 0.0f;
  int16_t raw  = ads.readADC_SingleEnded(2); // A2
  float   v    = ads.computeVolts(raw);
  float   arus = (v - offsetACS_Beban) / sensitivitasACS_Beban;
  if (abs(arus) < 0.10f) arus = 0;
  arusFilter_Beban = (0.85f * arusFilter_Beban) + (0.15f * arus);
  arusFilter_Beban = constrain(arusFilter_Beban, -50.0f, 50.0f);
  return arusFilter_Beban;
}

// ===================================================
// TEMT6000 (via ADS1115 channel A1)
// ===================================================
float bacaLuxTEMT6000() {
  if (!adsReady) return 0.0f;
  int16_t raw     = ads.readADC_SingleEnded(1); // A1
  float   voltage = ads.computeVolts(raw);
  float   lux     = voltage * 1000.0f;
  if (lux < 0) lux = 0;
  return lux;
}

// ===================================================
// KONEKSI WIFI
// ===================================================
void connectWiFi() {
  if (WiFi.status() == WL_CONNECTED) return;

  Serial.print("[WiFi] Menghubungkan ke ");
  Serial.println(ssid);

  WiFi.disconnect(true);
  delay(500);
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  int attempt = 0;
  while (WiFi.status() != WL_CONNECTED && attempt < 20) {
    delay(500);
    Serial.print(".");
    attempt++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] Terhubung! IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n[WiFi] Gagal terhubung. Lanjut tanpa WiFi.");
  }
}

// ===================================================
// CALLBACK MQTT
// ===================================================
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String msg = "";
  for (unsigned int i = 0; i < length; i++) msg += (char)payload[i];
  Serial.println("[MQTT CMD] " + msg);

  StaticJsonDocument<256> doc;
  if (deserializeJson(doc, msg)) return;

  if (doc.containsKey("mode")) {
    modeManual = (String(doc["mode"].as<const char*>()) == "manual");
    Serial.println("[CMD] Mode: " + String(modeManual ? "MANUAL" : "AUTO"));
  }

  if (modeManual) {
    if (doc.containsKey("servo_h")) {
      posisiH = constrain((int)doc["servo_h"], 10, 170);
      servoH.write(posisiH);
    }
    if (doc.containsKey("servo_v")) {
      posisiV = constrain((int)doc["servo_v"], 10, 170);
      servoV.write(posisiV);
    }
  }

  if (doc.containsKey("reset") && doc["reset"] == true) {
    posisiH = 90;
    posisiV = 90;
    servoH.write(posisiH);
    servoV.write(posisiV);
    Serial.println("[CMD] Posisi reset ke 90/90");
  }

  if (doc.containsKey("reset_energy") && doc["reset_energy"] == true) {
    energiWhPV    = 0;
    energiWhBeban = 0;
    Serial.println("[CMD] Energi direset ke 0");
  }
}

// ===================================================
// KONEKSI MQTT
// ===================================================
void connectMQTT() {
  if (WiFi.status() != WL_CONNECTED) return;
  if (mqttClient.connected()) return;

  int attempt = 0;
  while (!mqttClient.connected() && attempt < 5) {
    Serial.printf("[MQTT] Mencoba koneksi ke broker... (percobaan %d/5)\n", attempt + 1);
    String cid = "ESP32-PLTS-" + String(random(0xffff), HEX);

    bool ok = (strlen(mqttUser) > 0)
              ? mqttClient.connect(cid.c_str(), mqttUser, mqttPass)
              : mqttClient.connect(cid.c_str());

    if (ok) {
      Serial.println("[MQTT] Terhubung!");
      mqttClient.subscribe(TOPIC_CMD);
      return;
    } else {
      Serial.printf("[MQTT] Gagal rc=%d. Tunggu sebentar...\n", mqttClient.state());
      attempt++;
      delay(1000);
    }
  }

  if (!mqttClient.connected()) {
    Serial.println("[MQTT] Tidak berhasil terhubung. Akan dicoba lagi di iterasi berikutnya.");
  }
}

// ===================================================
// PUBLISH DATA KE MQTT
// ===================================================
void publishData(float voltPV,    float arusPV,
                 float voltBeban, float arusBeban,
                 float lux,
                 int atas,   int bawah,
                 int kiri,   int kanan,
                 int errorYaw, int errorPitch,
                 String arahYaw, String arahPitch) {

  float dayaPV    = voltPV    * arusPV;
  float dayaBeban = voltBeban * arusBeban;

  // Akumulasi energi
  unsigned long now   = millis();
  float         dtJam = (now - lastEnergiTime) / 3600000.0f;
  energiWhPV         += dayaPV    * dtJam;
  energiWhBeban      += dayaBeban * dtJam;
  lastEnergiTime      = now;

  String statEnergi;
  if      (energiWhPV < 10)  statEnergi = "RENDAH";
  else if (energiWhPV < 100) statEnergi = "SEDANG";
  else                        statEnergi = "TINGGI";

  StaticJsonDocument<768> doc;

  // Data PV
  doc["tegangan_pv"]    = serialized(String(voltPV,    2));
  doc["arus_pv"]        = serialized(String(arusPV,    3));
  doc["daya_pv"]        = serialized(String(dayaPV,    2));

  // Data Beban
  doc["tegangan_beban"] = serialized(String(voltBeban,  2));
  doc["arus_beban"]     = serialized(String(arusBeban,  3));
  doc["daya_beban"]     = serialized(String(dayaBeban,  2));

  // Data umum
  doc["cahaya"]         = serialized(String(lux,        1));
  doc["energi_pv"]      = serialized(String(energiWhPV,    3));
  doc["energi_beban"]   = serialized(String(energiWhBeban, 3));
  doc["status_energi"]  = statEnergi;

  // Solar tracker
  doc["pos_h"]          = posisiH;
  doc["pos_v"]          = posisiV;
  doc["error_yaw"]      = errorYaw;
  doc["error_pitch"]    = errorPitch;
  doc["arah_yaw"]       = arahYaw;
  doc["arah_pitch"]     = arahPitch;
  doc["mode"]           = modeManual ? "MANUAL" : "AUTO";

  // LDR
  doc["ldr_atas"]       = atas;
  doc["ldr_bawah"]      = bawah;
  doc["ldr_kiri"]       = kiri;
  doc["ldr_kanan"]      = kanan;

  // Status ADS1115
  doc["ads_status"]     = adsReady ? "OK" : "ERROR";

  char buf[768];
  serializeJson(doc, buf);

  if (mqttClient.publish(TOPIC_DATA, buf)) {
    Serial.println("[MQTT] Data terkirim.");
  } else {
    Serial.println("[MQTT] Gagal kirim data.");
  }
}

// ===================================================
// SETUP
// ===================================================
void setup() {
  Serial.begin(115200);
  delay(1000);

  // Inisialisasi I2C dan ADS1115
  Wire.begin(21, 22); // SDA = GPIO21, SCL = GPIO22
  if (!ads.begin()) {
    Serial.println("[ADS1115] GAGAL! Cek wiring I2C (SDA=21, SCL=22).");
    adsReady = false;
  } else {
    ads.setGain(GAIN_ONE); // Range ±4.096V, resolusi 0.125mV/bit
    adsReady = true;
    Serial.println("[ADS1115] Siap. Channel A0=Tegangan Beban, A1=TEMT6000");
  }

  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  servoH.attach(SERVO_HORIZONTAL);
  servoV.attach(SERVO_VERTICAL);
  servoH.write(posisiH);
  servoV.write(posisiV);
  delay(500);

  connectWiFi();

  mqttClient.setServer(mqttServer, mqttPort);
  mqttClient.setCallback(mqttCallback);
  mqttClient.setBufferSize(768);

  if (WiFi.status() == WL_CONNECTED) {
    connectMQTT();
  }

  lastEnergiTime = millis();
  Serial.println("===== SOLAR TRACKER READY =====");
}

// ===================================================
// LOOP
// ===================================================
void loop() {

  // Jaga koneksi WiFi & MQTT
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[WiFi] Koneksi terputus, mencoba reconnect...");
    connectWiFi();
    return;
  }

  if (!mqttClient.connected()) {
    connectMQTT();
    return;
  }

  mqttClient.loop();

  // ===================== BACA LDR =====================
  int atas  = bacaADC(LDR_ATAS);
  int bawah = bacaADC(LDR_BAWAH);
  int kiri  = bacaADC(LDR_KIRI);
  int kanan = bacaADC(LDR_KANAN);

  // ===================== BACA SENSOR PV =====================
  float voltPV  = bacaVoltagePV();
  float arusPV  = bacaArusPV();

  // ===================== BACA SENSOR BEBAN (via ADS1115) =====================
  float voltBeban = bacaVoltageBeban();
  float arusBeban = bacaArusBeban();

  // ===================== BACA CAHAYA (via ADS1115) =====================
  float lux = bacaLuxTEMT6000();

  // ===================== HITUNG ERROR =====================
  int errorYaw   = kiri - kanan;
  int errorPitch = atas  - bawah;

  String arahYaw   = "LOCK";
  String arahPitch = "LOCK";

  // ===================== KONTROL SERVO AUTO =====================
  if (!modeManual) {

    // Yaw (horizontal)
    if (min(kiri, kanan) < batasCahaya) {
      if      (errorYaw >  toleransiYaw)  { posisiH--; arahYaw = "RIGHT"; }
      else if (errorYaw < -toleransiYaw)  { posisiH++; arahYaw = "LEFT";  }
      else                                 { arahYaw = "CENTER"; }
    }

    // Pitch (vertikal)
    if (min(atas, bawah) < batasCahaya) {
      if      (errorPitch >  toleransiPitch) { posisiV--; arahPitch = "DOWN"; }
      else if (errorPitch < -toleransiPitch) { posisiV++; arahPitch = "UP";   }
      else                                    { arahPitch = "CENTER"; }
    }

    posisiH = constrain(posisiH, 10, 170);
    posisiV = constrain(posisiV, 10, 170);

    servoH.write(posisiH);
    servoV.write(posisiV);
  }

  // ===================== SERIAL OUTPUT =====================
  Serial.println("================================");
  Serial.printf("LDR  ATAS  : %d\n", atas);
  Serial.printf("LDR  BAWAH : %d\n", bawah);
  Serial.printf("LDR  KIRI  : %d\n", kiri);
  Serial.printf("LDR  KANAN : %d\n", kanan);
  Serial.println("--------------------------------");
  Serial.printf("ERROR YAW   : %d\n", errorYaw);
  Serial.printf("ERROR PITCH : %d\n", errorPitch);
  Serial.println("--------------------------------");
  Serial.printf("GERAK YAW   : %s\n", arahYaw.c_str());
  Serial.printf("GERAK PITCH : %s\n", arahPitch.c_str());
  Serial.println("--------------------------------");
  Serial.printf("VOLT PV     : %.2f V\n", voltPV);
  Serial.printf("ARUS PV     : %.3f A\n", arusPV);
  Serial.printf("DAYA PV     : %.2f W\n", voltPV * arusPV);
  Serial.println("--------------------------------");
  Serial.printf("VOLT BEBAN  : %.2f V\n", voltBeban);
  Serial.printf("ARUS BEBAN  : %.3f A\n", arusBeban);
  Serial.printf("DAYA BEBAN  : %.2f W\n", voltBeban * arusBeban);
  Serial.println("--------------------------------");
  Serial.printf("LUX         : %.1f\n", lux);
  Serial.printf("ADS1115     : %s\n", adsReady ? "OK" : "ERROR");
  Serial.printf("POS H / V   : %d / %d\n", posisiH, posisiV);
  Serial.printf("MODE        : %s\n", modeManual ? "MANUAL" : "AUTO");
  Serial.println("================================");

  // ===================== PUBLISH MQTT =====================
  unsigned long now = millis();
  if (now - lastPublish >= publishInterval) {
    lastPublish = now;
    publishData(voltPV, arusPV,
                voltBeban, arusBeban,
                lux,
                atas, bawah, kiri, kanan,
                errorYaw, errorPitch,
                arahYaw, arahPitch);
  }

  delay(1000);
}
